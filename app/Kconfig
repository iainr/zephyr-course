source "Kconfig.zephyr"

menuconfig LED_SUBSYSTEM
    bool "LED Subsystem"

if LED_SUBSYSTEM

choice BLINK_SLEEP_TIME
    prompt "Blink sleep time"
    default BLINK_SLEEP_TIME_500MS

config BLINK_SLEEP_TIME_250MS
    bool "250ms"

config BLINK_SLEEP_TIME_500MS
    bool "500ms"

config BLINK_SLEEP_TIME_1S
    bool "1s"

config BLINK_SLEEP_TIME_2S
    bool "2s"

endchoice

menuconfig ADVANCED_LED_SETTINGS
    bool "Advanced LED settings"

if ADVANCED_LED_SETTINGS

config LED_BRIGHTNESS
    int "LED brightness"
    default 100
    range 0 100

config LED_FADE_DURATION
    int "LED Fade Duration"
    default 500
    range 0 5000

endif # ADVANCED_LED_SETTINGS

menu "Expert settings"
    visible if ADVANCED_LED_SETTINGS

config LED_DEBUGGING
    bool "Enable LED debugging"
    default n

config CUSTOM_BLINK_PATTERN
    bool "Custom blink pattern"
    default n

endmenu # Expert settings


config BLINK_SLEEP_MS
    int
    default 250 if BLINK_SLEEP_TIME_250MS
    default 500 if BLINK_SLEEP_TIME_500MS
    default 1000 if BLINK_SLEEP_TIME_1S
    default 2000 if BLINK_SLEEP_TIME_2S

endif # LED_SUBSYSTEM